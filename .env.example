# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# Set QDRANT_HOST to your cluster hostname and QDRANT_API_KEY to your cloud key.
# Leaving QDRANT_API_KEY empty → self-hosted mode (host/port from config.yaml).
QDRANT_HOST=xyz.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=

# ── Postgres ──────────────────────────────────────────────────────────────────
# Password for the user/host/db defined in config.yaml.
# Set DATABASE_URL to override the full DSN (e.g. managed DBs on Railway/Supabase).
DATABASE_PASSWORD=docsmcp
# DATABASE_URL=postgres://user:password@host:5432/db?sslmode=require

# ── ClickHouse Cloud ──────────────────────────────────────────────────────────
# Native protocol DSN for ClickHouse Cloud (port 9440, TLS). Leave empty to disable.
CLICKHOUSE_DSN=https://default:<password>@<host>:8443/default?secure=true

# ── Crawler ───────────────────────────────────────────────────────────────────
# Firecrawl API key — optional. Enables the last-resort crawler fallback strategy.
# Leave empty to skip Firecrawl (chain stops at PlainHTTP → Chromedp).
FIRECRAWL_URL=
